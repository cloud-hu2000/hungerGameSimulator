{
  "version": 2,
  "functions": {
    "api/health.js": { "runtime": "@vercel/node@3" },
    "api/simulate.js": { "runtime": "@vercel/node@3" },
    "api/simulations/index.js": { "runtime": "@vercel/node@3" },
    "api/simulations/[id].js": { "runtime": "@vercel/node@3" },
    "api/events/stats.js": { "runtime": "@vercel/node@3" }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Credentials", "value": "true" },
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PUT, DELETE, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization, X-Requested-With" }
      ]
    }
  ]
}
